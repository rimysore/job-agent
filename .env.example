# ╔══════════════════════════════════════════════════════════════╗
# ║     🤖 JobHunter AI — Environment Variables                 ║
# ║     Copy this to .env and fill in your values.              ║
# ║     For GitHub Actions, add these as Repository Secrets.    ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Required ─────────────────────────────────────────────────
# Google Gemini API key (FREE — no credit card needed!)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ── Recommended ──────────────────────────────────────────────
# Serper API key for Google search (job discovery + recruiter finding)
# Get one at: https://serper.dev/ (free tier: 2500 searches/month)
SERPER_API_KEY=...

# ── Email Notifications ──────────────────────────────────────
# Gmail App Password for sending notifications
# 1. Enable 2FA on your Google account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Create an app password for "Mail"
SMTP_EMAIL=your-sender@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# Your email to receive notifications (defaults to profile.yaml value)
JH_EMAIL=rithviksit@gmail.com

# ── Optional Overrides ───────────────────────────────────────
JH_NAME=
JH_PHONE=
JH_LOCATION=
